# =============================================================================
# Iceberg Configuration
# =============================================================================

# Catalog type: glue, rest, hive, sql, dynamodb
ICEBERG_CATALOG_TYPE=glue

# Catalog name (logical identifier — used as PyIceberg catalog alias)
ICEBERG_CATALOG_NAME=glue_catalog

# --- AWS Glue catalog settings (when ICEBERG_CATALOG_TYPE=glue) ---
# AWS region where the Glue catalog lives
ICEBERG_GLUE_REGION=us-east-1
# (Optional) Named AWS profile from ~/.aws/credentials.  Leave blank to use
# the default credential chain (env vars, instance role, etc.)
ICEBERG_GLUE_PROFILE=default
# (Optional) Glue catalog ID — defaults to your AWS account ID if blank
ICEBERG_GLUE_CATALOG_ID=

# --- REST catalog settings (when ICEBERG_CATALOG_TYPE=rest) ---
# ICEBERG_CATALOG_URI=http://localhost:8181

# --- S3 / storage (used by both Glue and REST catalogs) ---
# Only needed if you must override default AWS credentials or use a
# non-AWS S3-compatible store (e.g. MinIO).  For standard AWS setups the
# SDK credential chain (env vars, ~/.aws/credentials, IAM role) is used.
ICEBERG_S3_ENDPOINT=
ICEBERG_S3_ACCESS_KEY=
ICEBERG_S3_SECRET_KEY=
ICEBERG_S3_REGION=us-east-1

# Warehouse path (required for REST; optional for Glue — Glue stores this
# in the catalog itself)
ICEBERG_WAREHOUSE=

# Namespace (database) in the Iceberg catalog
# For Glue this is the Glue database name (e.g. "my_iceberg_db")
ICEBERG_NAMESPACE=rs_cdkdev_rubyx00001_exposure_db

# Default table — used when you run without --table / --all-tables
# For multi-table runs, use CLI flags instead:
#   python ingest.py --table ns.tcontract --table ns.tlocation
#   python ingest.py --all-tables
ICEBERG_TABLE=

# =============================================================================
# SQL Server Configuration
# =============================================================================

# SQL Server connection
SQLSERVER_HOST=10.193.55.24
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=AIRExposure_test
SQLSERVER_SCHEMA=dbo
SQLSERVER_TABLE=
SQLSERVER_USERNAME=vssadmin
SQLSERVER_PASSWORD=Vssadmin@12345!

# Authentication: sql_login | windows | azure_ad
SQLSERVER_AUTH_TYPE=sql_login

# Optional: ODBC driver name (default: ODBC Driver 18 for SQL Server)
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server

# Trust server certificate (useful for dev/self-signed certs)
SQLSERVER_TRUST_CERT=yes

# =============================================================================
# Ingestion Settings
# =============================================================================

# Load mode: full | incremental
LOAD_MODE=full

# Batch size for SQL Server inserts
BATCH_SIZE=5000

# SQL write backend: pyodbc | bcp
# - pyodbc: pure-Python path (default)
# - bcp: external SQL Server bulk copy utility (much faster on large writes)
WRITE_BACKEND=pyodbc

# Path to bcp executable (only used when WRITE_BACKEND=bcp)
BCP_PATH=bcp

# Batch size passed to bcp (-b)
BCP_BATCH_SIZE=50000

# Optional temp directory for bcp data files (blank = system temp dir)
BCP_TEMP_DIR=

# Delimiters for bcp text file mode. Keep uncommon markers to avoid collisions
# with real data values.
BCP_FIELD_TERMINATOR=|~|
BCP_ROW_TERMINATOR=~|~\n

# For incremental mode: path to store last snapshot ID
STATE_FILE=.ingestion_state.json

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Naming convention for auto-generated target columns
# Options: PascalCase, camelCase, UPPER_SNAKE, lower_snake, as_is
# Only used when the target table does NOT already exist.
# When the target table exists, columns are auto-mapped intelligently.
NAMING_CONVENTION=as_is

# Path to mapping config file (generated by Step 1, consumed by Step 2)
MAPPING_FILE=mapping_config.json
