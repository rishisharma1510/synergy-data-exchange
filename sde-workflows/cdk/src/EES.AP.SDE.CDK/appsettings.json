{
  "Settings": {
    "StackTemplatePrefix": "ss-cdk-",
    "Qualifier": "sde",
    "CostCategory": "corporatehosting",
    "Category": "Tenant",
    "CapCode": "v03008",
    "IsCapitalizable": "1",
    "DevPhase": "not_applicable",
    "Tenant": "dclegend",
    "Component": "Synergy Data Exchange",
    "DeploymentZone": "private",
    "MgmtModel": "cattle",
    "OSType": "linux",
    "BusinessUnit": "ees",
    "ProductName": "synergystudio",
    "Department": "sdg",
    "ProductOwner": " ",
    "Team": "cipher",
    "ResourceType": "single",
    "SubFeature": "",
    "Feature": "bidirectional data pipeline for Iceberg and SQL Server",
    "UserName": "vnigam::rsharma::gpal",
    "TenantId": ""
  },

  "ApplicationVariables": {
    "ImageTag": "latest",
    "VpcId": "vpc-024efe736c9fe2a15",
    "SubnetIds": "subnet-00d8ca339521c44c0,subnet-07ac9cca6864c1c8c,subnet-07c569a1f9e4ea131,subnet-08b0b5d09497b90f1,subnet-0a7f93123774da400",
    "SecurityGroupIds": "sg-0747b695cf75d47db",
    "TenantContextLambda": "rs-cdk{stage}-ap-tenant-context-lambda",
    "AppTokenSecret": "rs-cdk{stage}-app-token-secret",
    "IdentityProviderTokenEndpoint": ""
  },

  "SDEConfiguration": {
    "Ecr": {
      "ExpressRepositoryName": "sde-express",
      "StandardRepositoryName": "sde-standard",
      "BatchRepositoryName": "sde-batch",
      "ImageTag": "{#ImageTag}"
    },
    "Fargate": {
      "ClusterName": "sde-cluster",
      "ExpressCpu": 8192,
      "ExpressMemory": 61440,
      "ExpressMaxParallelTables": 5,
      "EphemeralStorageGiB": 200,
      "StandardCpu": 16384,
      "SqlEdition": "Standard",
      "StandardMemory": 122880,
      "StandardMaxParallelTables": 10,
      "ExecutionRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-fargate-exec-role",
        "AssumedBy": "ecs-tasks.amazonaws.com",
        "AwsManagedPolicies": [ "service-role/AmazonECSTaskExecutionRolePolicy" ],
        "InlinePolicies": []
      },
      "TaskRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-fargate-task-role",
        "AssumedBy": "ecs-tasks.amazonaws.com",
        "AwsManagedPolicies": [],
        "InlinePolicies": [
          {
            "Name": "sde-fargate-policy",
            "Description": "Policy for Synergy Data Exchange Fargate tasks",
            "Version": "2012-10-17",
            "Statements": [
              {
                "Sid": "S3TenantBucketAccess",
                "Effect": "Allow",
                "Actions": [ "s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket", "s3:GetBucketLocation" ],
                "Resources": [ 
                  "arn:aws:s3:::rs-cdk{stage}-*",
                  "arn:aws:s3:::rs-cdk{stage}-*/*",
                  "arn:aws:s3:::ss-cdk{stage}-*",
                  "arn:aws:s3:::ss-cdk{stage}-*/*"
                ]
              },
              {
                "Sid": "GlueCatalogAccess",
                "Effect": "Allow",
                "Actions": [ "glue:GetDatabase", "glue:GetDatabases", "glue:GetTable", "glue:GetTables", "glue:GetPartitions", "glue:CreateTable", "glue:UpdateTable", "glue:DeleteTable", "glue:BatchGetPartition", "glue:GetTableVersion", "glue:GetTableVersions" ],
                "Resources": [ 
                  "arn:aws:glue:{region}:{account-id}:catalog",
                  "arn:aws:glue:{region}:{account-id}:database/*",
                  "arn:aws:glue:{region}:{account-id}:table/*/*"
                ]
              },
              {
                "Sid": "CloudWatchLogsSynergyDataExchange",
                "Effect": "Allow",
                "Actions": [ "logs:CreateLogStream", "logs:PutLogEvents", "logs:DescribeLogStreams" ],
                "Resources": [ 
                  "arn:aws:logs:{region}:{account-id}:log-group:/ecs/sde/*",
                  "arn:aws:logs:{region}:{account-id}:log-group:/ecs/sde/*:*"
                ]
              },
              {
                "Sid": "StepFunctionsCallback",
                "Effect": "Allow",
                "Actions": [ "states:SendTaskSuccess", "states:SendTaskFailure", "states:SendTaskHeartbeat" ],
                "Resources": [ 
                  "arn:aws:states:{region}:{account-id}:stateMachine:ss-cdk{stage}-sde-*"
                ]
              },
              {
                "Sid": "LambdaInvoke",
                "Effect": "Allow",
                "Actions": [ "lambda:InvokeFunction" ],
                "Resources": [ "arn:aws:lambda:{region}:{account-id}:function:rs-cdk{stage}-ap-tenant-context-lambda" ]
              },
              {
                "Sid": "SecretsAccess",
                "Effect": "Allow",
                "Actions": [ "secretsmanager:GetSecretValue" ],
                "Resources": [ "arn:aws:secretsmanager:{region}:{account-id}:secret:rs-cdk{stage}-*" ]
              }
            ]
          }
        ]
      }
    },
    "Batch": {
      "ComputeEnvironmentName": "sde-batch-ce",
      "JobQueueName": "sde-batch-queue",
      "JobDefinitionName": "sde-batch-job",
      "SqlEdition": "Standard",
      "JobVcpus": 16,
      "JobMemory": 65536,
      "JobMaxParallelTables": 16,
      "MaxVcpus": 1024,
      "InstanceRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-batch-instance-role",
        "AssumedBy": "ec2.amazonaws.com",
        "AwsManagedPolicies": [ "service-role/AmazonEC2ContainerServiceforEC2Role", "AmazonSSMManagedInstanceCore" ],
        "InlinePolicies": [
          {
            "Name": "sde-batch-ebs-policy",
            "Description": "Policy for EBS volume management - some EC2 actions require * resources",
            "Version": "2012-10-17",
            "Statements": [
              {
                "Sid": "EBSDescribe",
                "Effect": "Allow",
                "Actions": [ "ec2:DescribeVolumes", "ec2:DescribeVolumeStatus", "ec2:DescribeInstances" ],
                "Resources": ["*"]
              },
              {
                "Sid": "EBSVolumeManagement",
                "Effect": "Allow",
                "Actions": [ "ec2:AttachVolume", "ec2:DetachVolume", "ec2:ModifyVolume" ],
                "Resources": [
                  "arn:aws:ec2:{region}:{account-id}:volume/*",
                  "arn:aws:ec2:{region}:{account-id}:instance/*"
                ],
                "Conditions": {
                  "StringEquals": {
                    "aws:ResourceTag/Team": "cipher"
                  }
                }
              },
              {
                "Sid": "EBSCreateVolume",
                "Effect": "Allow",
                "Actions": [ "ec2:CreateVolume" ],
                "Resources": [ "arn:aws:ec2:{region}:{account-id}:volume/*" ],
                "Conditions": {
                  "StringEquals": {
                    "aws:RequestTag/Team": "cipher"
                  }
                }
              },
              {
                "Sid": "EBSDeleteVolume",
                "Effect": "Allow",
                "Actions": [ "ec2:DeleteVolume" ],
                "Resources": [ "arn:aws:ec2:{region}:{account-id}:volume/*" ],
                "Conditions": {
                  "StringEquals": {
                    "aws:ResourceTag/Team": "cipher"
                  }
                }
              },
              {
                "Sid": "EBSTagging",
                "Effect": "Allow",
                "Actions": [ "ec2:CreateTags" ],
                "Resources": [ "arn:aws:ec2:{region}:{account-id}:volume/*" ],
                "Conditions": {
                  "StringEquals": {
                    "ec2:CreateAction": "CreateVolume"
                  }
                }
              }
            ]
          }
        ]
      },
      "ExecutionRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-batch-exec-role",
        "AssumedBy": "ecs-tasks.amazonaws.com",
        "AwsManagedPolicies": [ "service-role/AmazonECSTaskExecutionRolePolicy" ],
        "InlinePolicies": []
      },
      "JobRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-batch-job-role",
        "AssumedBy": "ecs-tasks.amazonaws.com",
        "AwsManagedPolicies": [],
        "InlinePolicies": [
          {
            "Name": "sde-batch-job-policy",
            "Description": "Policy for Synergy Data Exchange Batch jobs",
            "Version": "2012-10-17",
            "Statements": [
              {
                "Sid": "S3TenantBucketAccess",
                "Effect": "Allow",
                "Actions": [ "s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket", "s3:GetBucketLocation" ],
                "Resources": [ 
                  "arn:aws:s3:::rs-cdk{stage}-*",
                  "arn:aws:s3:::rs-cdk{stage}-*/*",
                  "arn:aws:s3:::ss-cdk{stage}-*",
                  "arn:aws:s3:::ss-cdk{stage}-*/*"
                ]
              },
              {
                "Sid": "GlueCatalogAccess",
                "Effect": "Allow",
                "Actions": [ "glue:GetDatabase", "glue:GetDatabases", "glue:GetTable", "glue:GetTables", "glue:GetPartitions", "glue:CreateTable", "glue:UpdateTable", "glue:DeleteTable", "glue:BatchGetPartition", "glue:GetTableVersion", "glue:GetTableVersions" ],
                "Resources": [ 
                  "arn:aws:glue:{region}:{account-id}:catalog",
                  "arn:aws:glue:{region}:{account-id}:database/*",
                  "arn:aws:glue:{region}:{account-id}:table/*/*"
                ]
              },
              {
                "Sid": "CloudWatchLogsBatch",
                "Effect": "Allow",
                "Actions": [ "logs:CreateLogStream", "logs:PutLogEvents", "logs:DescribeLogStreams" ],
                "Resources": [ 
                  "arn:aws:logs:{region}:{account-id}:log-group:/aws/batch/ss-cdk{stage}-sde-*:*"
                ]
              },
              {
                "Sid": "StepFunctionsCallback",
                "Effect": "Allow",
                "Actions": [ "states:SendTaskSuccess", "states:SendTaskFailure", "states:SendTaskHeartbeat" ],
                "Resources": [ "arn:aws:states:{region}:{account-id}:stateMachine:ss-cdk{stage}-sde-*" ]
              },
              {
                "Sid": "LambdaInvoke",
                "Effect": "Allow",
                "Actions": [ "lambda:InvokeFunction" ],
                "Resources": [ "arn:aws:lambda:{region}:{account-id}:function:rs-cdk{stage}-ap-tenant-context-lambda" ]
              },
              {
                "Sid": "SecretsAccess",
                "Effect": "Allow",
                "Actions": [ "secretsmanager:GetSecretValue" ],
                "Resources": [ "arn:aws:secretsmanager:{region}:{account-id}:secret:rs-cdk{stage}-*" ]
              }
            ]
          }
        ]
      }
    },
    "StepFunctions": {
      "ExtractionStateMachineName": "sde-extraction",
      "IngestionStateMachineName": "sde-ingestion",
      "ThresholdSmallGb": 9,
      "ThresholdLargeGb": 80,
      "LambdaRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-size-estimator-role",
        "AssumedBy": "lambda.amazonaws.com",
        "AwsManagedPolicies": [
          "service-role/AWSLambdaBasicExecutionRole"
        ],
        "InlinePolicies": [
          {
            "PolicyName": "SizeEstimatorPolicy",
            "Statements": [
              {
                "Sid": "GlueReadAccess",
                "Effect": "Allow",
                "Actions": [
                  "glue:GetTable",
                  "glue:GetTables",
                  "glue:GetDatabase",
                  "glue:GetDatabases",
                  "glue:GetPartitions"
                ],
                "Resources": ["*"]
              },
              {
                "Sid": "S3ReadAccess",
                "Effect": "Allow",
                "Actions": [
                  "s3:GetObject",
                  "s3:GetObjectVersion",
                  "s3:ListBucket",
                  "s3:HeadObject"
                ],
                "Resources": ["*"]
              },
              {
                "Sid": "AthenaAccess",
                "Effect": "Allow",
                "Actions": [
                  "athena:StartQueryExecution",
                  "athena:GetQueryExecution",
                  "athena:GetQueryResults",
                  "athena:StopQueryExecution"
                ],
                "Resources": ["*"]
              },
              {
                "Sid": "InvokeTenantContext",
                "Effect": "Allow",
                "Actions": ["lambda:InvokeFunction"],
                "Resources": ["arn:aws:lambda:{region}:{account-id}:function:*-tenant-context-*"]
              },
              {
                "Sid": "ReadAppToken",
                "Effect": "Allow",
                "Actions": ["secretsmanager:GetSecretValue"],
                "Resources": ["arn:aws:secretsmanager:{region}:{account-id}:secret:*app-token*"]
              }
            ]
          }
        ]
      },
      "StateMachineRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-sfn-role",
        "AssumedBy": "states.amazonaws.com",
        "AwsManagedPolicies": [],
        "InlinePolicies": [
          {
            "PolicyName": "StepFunctionsPolicy",
            "Statements": [
              {
                "Sid": "InvokeSizeEstimatorLambda",
                "Effect": "Allow",
                "Actions": [ "lambda:InvokeFunction" ],
                "Resources": [
                  "arn:aws:lambda:{region}:{account-id}:function:ss-cdk{stage}-sde-size-estimator"
                ]
              },
              {
                "Sid": "EcsRunTask",
                "Effect": "Allow",
                "Actions": [ "ecs:RunTask" ],
                "Resources": [ 
                  "arn:aws:ecs:{region}:{account-id}:task-definition/ss-cdk{stage}-sde-express:*",
                  "arn:aws:ecs:{region}:{account-id}:task-definition/ss-cdk{stage}-sde-standard:*"
                ]
              },
              {
                "Sid": "EcsManageTasks",
                "Effect": "Allow",
                "Actions": [ "ecs:StopTask", "ecs:DescribeTasks", "ecs:TagResource" ],
                "Resources": [ 
                  "arn:aws:ecs:{region}:{account-id}:task/ss-cdk{stage}-sde-cluster/*"
                ]
              },
              {
                "Sid": "PassRoleToEcs",
                "Effect": "Allow",
                "Actions": [ "iam:PassRole" ],
                "Resources": [
                  "arn:aws:iam::{account-id}:role/ss-cdk{stage}-sde-fargate-exec-role",
                  "arn:aws:iam::{account-id}:role/ss-cdk{stage}-sde-fargate-task-role",
                  "arn:aws:iam::{account-id}:role/rs-cdk*"
                ],
                "Condition": {
                  "StringEquals": { "iam:PassedToService": "ecs-tasks.amazonaws.com" }
                }
              },
              {
                "Sid": "BatchSubmitJob",
                "Effect": "Allow",
                "Actions": [ "batch:SubmitJob" ],
                "Resources": [
                  "arn:aws:batch:{region}:{account-id}:job-queue/ss-cdk{stage}-sde-*",
                  "arn:aws:batch:{region}:{account-id}:job-definition/ss-cdk{stage}-sde-*"
                ]
              },
              {
                "Sid": "BatchManageJobs",
                "Effect": "Allow",
                "Actions": [ "batch:DescribeJobs", "batch:TerminateJob" ],
                "Resources": [ "arn:aws:batch:{region}:{account-id}:job/*" ]
              },
              {
                "Sid": "CloudWatchLogsDelivery",
                "Effect": "Allow",
                "Actions": [
                  "logs:CreateLogDelivery",
                  "logs:GetLogDelivery",
                  "logs:UpdateLogDelivery",
                  "logs:DeleteLogDelivery",
                  "logs:ListLogDeliveries",
                  "logs:PutResourcePolicy",
                  "logs:DescribeResourcePolicies",
                  "logs:DescribeLogGroups"
                ],
                "Resources": ["*"]
              },
              {
                "Sid": "XRayTracing",
                "Effect": "Allow",
                "Actions": [
                  "xray:PutTraceSegments",
                  "xray:PutTelemetryRecords",
                  "xray:GetSamplingRules",
                  "xray:GetSamplingTargets"
                ],
                "Resources": ["*"]
              },
              {
                "Sid": "EventBridgeRules",
                "Effect": "Allow",
                "Actions": [
                  "events:PutTargets",
                  "events:PutRule",
                  "events:DescribeRule"
                ],
                "Resources": [ 
                  "arn:aws:events:{region}:{account-id}:rule/StepFunctionsGetEventsForBatchJobsRule",
                  "arn:aws:events:{region}:{account-id}:rule/StepFunctionsGetEventsForECSTaskRule"
                ]
              }
            ]
          }
        ]
      },
      "LayerVersionArns": [ "{#DT_ONE_AGENT_LAYER_ARN_PYTHON}" ],
      "LambdaEnvironmentVariables": {
        "DT_CLUSTER_ID": "{#DT_CLUSTER_ID}",
        "DT_CONNECTION_AUTH_TOKEN": "{#DT_CONNECTION_AUTH_TOKEN}",
        "DT_CONNECTION_BASE_URL": "{#DT_CONNECTION_BASE_URL}",
        "DT_LOG_COLLECTION_AUTH_TOKEN": "{#DT_LOG_COLLECTION_AUTH_TOKEN}",
        "DT_TENANT": "{#DT_TENANT}",
        "AWS_LAMBDA_EXEC_WRAPPER": "{#AWS_LAMBDA_EXEC_WRAPPER}"
      }
    },
    "Vpc": {
      "VpcId": "{#VpcId}",
      "SubnetIds": "{#SubnetIds}",
      "SecurityGroupIds": "{#SecurityGroupIds}"
    },
    "Api": {
      "TenantContextLambda": "{#TenantContextLambda}",
      "AppTokenSecret": "{#AppTokenSecret}",
      "IdentityProviderTokenEndpoint": "{#IdentityProviderTokenEndpoint}"
    },
    "Monitoring": {
      "ReportBucket": "ss-cdk{stage}-metrics-shared",
      "ReportPrefix": "{stage}/usagebyservice/SQL_SPLA",
      "ConcurrentCoresWarningThreshold": 80,
      "ConcurrentCoresCriticalThreshold": 160,
      "AlertEmailAddress": "",
      "TrackerRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-spla-tracker-role",
        "AssumedBy": "lambda.amazonaws.com",
        "AwsManagedPolicies": [ "service-role/AWSLambdaBasicExecutionRole" ],
        "InlinePolicies": [
          {
            "Name": "spla-tracker-policy",
            "Description": "Allows SPLA tracker to read SFN history and publish CW metrics",
            "Version": "2012-10-17",
            "Statements": [
              {
                "Sid": "SfnReadExecutions",
                "Effect": "Allow",
                "Actions": [
                  "states:DescribeExecution",
                  "states:GetExecutionHistory",
                  "states:ListExecutions"
                ],
                "Resources": [
                  "arn:aws:states:{region}:{account-id}:stateMachine:ss-cdk{stage}-sde-*",
                  "arn:aws:states:{region}:{account-id}:execution:ss-cdk{stage}-sde-*:*"
                ]
              },
              {
                "Sid": "CloudWatchCustomMetrics",
                "Effect": "Allow",
                "Actions": [ "cloudwatch:PutMetricData" ],
                "Resources": [ "*" ]
              }
            ]
          }
        ]
      },
      "ReporterRoleConfig": {
        "RoleName": "ss-cdk{stage}-sde-spla-reporter-role",
        "AssumedBy": "lambda.amazonaws.com",
        "AwsManagedPolicies": [ "service-role/AWSLambdaBasicExecutionRole" ],
        "InlinePolicies": [
          {
            "Name": "spla-reporter-policy",
            "Description": "Allows monthly SPLA reporter to write S3 reports",
            "Version": "2012-10-17",
            "Statements": [
              {
                "Sid": "S3ReportUpload",
                "Effect": "Allow",
                "Actions": [ "s3:PutObject", "s3:GetObject", "s3:ListBucket" ],
                "Resources": [
                  "arn:aws:s3:::ss-cdk{stage}-metrics-shared",
                  "arn:aws:s3:::ss-cdk{stage}-metrics-shared/*"
                ]
              }
            ]
          }
        ]
      }
    }
  }
}
