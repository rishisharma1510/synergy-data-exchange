# =============================================================================
# sde-workflows .gitignore  (Python / CDK / AWS)
# =============================================================================

# --- Environment & secrets (NEVER commit real credentials) ---
.env
.env.local
.env.*.local
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# --- CDK build output (generated by `cdk synth`) — all levels ---
cdk.out/

# --- CDK .NET project build artifacts ---
cdk/src/**/bin/
cdk/src/**/obj/
cdk/temp_inspect/

# --- CDK lock files ---
*.lock

# --- Misc temp/scratch files ---
_diag_*.py
_diag_*.txt
_fargate_test.py
_tmp_*.py
tmp_*.json

# --- AWS SAM / Serverless ---
.aws-sam/

# --- Docker ---
.dockerignore

# --- drawio backup files ---
*.drawio.bkp
.$*.drawio.bkp
