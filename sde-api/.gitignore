# =============================================================================
# sde-api .gitignore  (.NET / C# / CDK)
# =============================================================================

# --- .NET build outputs ---
bin/
obj/
out/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# --- NuGet ---
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.lock.json
!packages.lock.json

# --- Publish profiles ---
**/Properties/PublishProfiles/

# --- CDK build output (generated by `cdk synth` / `cdk deploy`) ---
cdk/cdk.out/

# --- AWS Lambda publish artifacts ---
publish/

# --- Logs & crash dumps ---
*.log
*.tmp
TestResults/
